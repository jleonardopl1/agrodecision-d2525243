# Frontend (Vite) — valores públicos; o RLS protege os dados.
# Sem .env o app usa os valores padrão do projeto (src/integrations/supabase/client.ts).
VITE_SUPABASE_URL=https://hacobjcbamavimzdtcki.supabase.co
